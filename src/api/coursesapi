import axiosClient from './axiosClient';

function normalizeCourse(course) {
  return {
    courseId: course.courseId ?? course.CourseId,
    instituteId: course.instituteId ?? course.InstituteId,
    courseName: course.courseName ?? course.CourseName ?? '',
    CourseCategory: course.CourseCategory ?? course.courseCategory ?? '',
    description: course.description ?? course.Description ?? '',
    fees: course.fees ?? course.Fees ?? null,
    duration: course.duration ?? course.Duration ?? '',
    eligibility: course.eligibility ?? course.Eligibility ?? '',
    isAIFetched: course.isAIFetched ?? course.IsAIFetched ?? false,
    isApproved: course.isApproved ?? course.IsApproved ?? false,
    isActive: course.isActive ?? course.IsActive ?? false,
    createdAt: course.createdAt ?? course.CreatedAt,
    rateType: course.rateType ?? course.RateType ?? '',
    commissionRate: course.commissionRate ?? course.CommissionRate ?? 0,
    campus: course.campus ?? course.Campus ?? '',
    level: course.level ?? course.Level ?? '',
    programLink: course.programLink ?? course.ProgramLink ?? '',
    cricosCode: course.cricosCode ?? course.CricosCode ?? '',
    intake: course.intake ?? course.Intake ?? '',
    englishReq: course.englishReq ?? course.EnglishReq ?? '',
    scholarshipsDetails: course.scholarshipsDetails ?? course.ScholarshipsDetails ?? '',
    programDescription: course.programDescription ?? course.ProgramDescription ?? '',
    addmissionRequirements: course.addmissionRequirements ?? course.AddmissionRequirements ?? '',
    programLogo: course.programLogo ?? course.ProgramLogo ?? '',
    instituteName: course.instituteName ?? course.InstituteName ?? '',
  };
}

/**
 * Fetch all courses, optionally filtered by instituteId.
 * Backend also returns GstPercentage alongside the list -
 * we surface both in case you need GST for fee display later.
 */
export async function fetchCourses(instituteId) {
  const { data } = await axiosClient.get('/api/courses', {
    params: instituteId ? { instituteId } : {},
  });

  const rawCourses = data.courses ?? data.Courses ?? [];
  const gstPercentage = data.gstPercentage ?? data.GstPercentage ?? 0;

  return {
    gstPercentage,
    courses: rawCourses.map((c) => ({
      id: String(c.courseId ?? c.CourseId),
      ...normalizeCourse(c),
    })),
  };
}

export async function fetchCourseById(courseId) {
  const { data } = await axiosClient.get(`/api/courses/${courseId}`);
  return normalizeCourse(data);
}

export async function createCourse(form) {
  
  const instituteId = Number(form.instituteId);

  if (!instituteId) {
    throw new Error('Please select an institute');
  }

  if (!form.courseName?.trim()) {
    throw new Error('Course name is required');
  }

  const formData = new FormData();
  formData.append('InstituteId', instituteId);
  formData.append('CourseName', form.courseName.trim());
  formData.append("CourseCategory", form.CourseCategory || "");
  formData.append('Description', form.description || '');
  formData.append('Fees', form.fees !== '' && form.fees != null ? Number(form.fees): '');
  formData.append('Duration', form.duration || '');
  formData.append('Eligibility', form.eligibility || '');
  formData.append('IsAIFetched', Boolean(form.isAIFetched));
  formData.append('Campus', form.campus || '');
  formData.append('Level', form.level || '');
  formData.append('ProgramLink', form.programLink || '');
  formData.append('CricosCode', form.cricosCode || '');
  formData.append('Intake', form.intake || '');
  formData.append('EnglishReq', form.englishReq || '');
  formData.append( 'ScholarshipsDetails',form.scholarshipsDetails || '');
  formData.append('ProgramDescription', form.programDescription || '' );
  formData.append('AddmissionRequirements',form.addmissionRequirements || '');
  formData.append('ProgramLogo', form.programLogo);
  formData.append('IsApproved', Boolean(form.isApproved));
  formData.append('IsActive', Boolean(form.isActive));

  const { data } = await axiosClient.post(
    '/api/courses',
    formData
  );

  return normalizeCourse(data);
}

export async function updateCourse(courseId, form) {
  const instituteId = Number(form.instituteId);

  if (!form.courseName?.trim()) {
    throw new Error('Course name is required');
  }

  const formData = new FormData();

  formData.append("InstituteId", instituteId);
  formData.append("CourseName", form.courseName.trim());
  formData.append("CourseCategory", form.CourseCategory || "");
  formData.append("Description", form.description || "");
  formData.append("Fees", form.fees || "");
  formData.append("Duration", form.duration || "");
  formData.append("Eligibility", form.eligibility || "");
  formData.append("Campus", form.campus || "");
  formData.append("Level", form.level || "");
  formData.append("ProgramLink", form.programLink || "");
  formData.append("CricosCode", form.cricosCode || "");
  formData.append("Intake", form.intake || "");
  formData.append("EnglishReq", form.englishReq || "");
  formData.append("ScholarshipsDetails", form.scholarshipsDetails || "");
  formData.append("ProgramDescription", form.programDescription || "");
  formData.append("AddmissionRequirements", form.addmissionRequirements || "");

  if (form.programLogo instanceof File) {
      formData.append("ProgramLogo", form.programLogo);
  }

  formData.append("IsApproved", form.isApproved === "Yes");
  formData.append("IsActive", form.isActive === "Yes");

  const { data } = await axiosClient.put(
      `/api/courses/${courseId}`,
      formData
  );

  return normalizeCourse(data);
}
export async function fetchCourseList() {
  const { data } = await axiosClient.get('/api/courses/GetCourses');
  const list = Array.isArray(data)
    ? data
    : (data?.courses ?? data?.Courses ?? data?.data ?? data?.Data ?? []);

  let instituteNameById = {};
  try {
    const { fetchUniqueInstituteNames } = await import('./institutesScrappingApi');
    const institutes = await fetchUniqueInstituteNames();
    instituteNameById = Object.fromEntries(
      (institutes ?? []).map((item) => [String(item.id), item.name || '']),
    );
  } catch {
    instituteNameById = {};
  }

  return (list ?? []).map((raw) => {
    const course = normalizeCourse(raw);
    return {
      ...course,
      id: String(course.courseId),
      CourseCategory: course.CourseCategory || '',
      instituteName:
        course.instituteName ||
        instituteNameById[String(course.instituteId)] ||
        '',
    };
  });
}
export async function approveCourse(courseId) {
  const { data } = await axiosClient.put(`/api/courses/${courseId}/approve`);
  return normalizeCourse(data);
}

export async function deleteCourse(courseId) {
  await axiosClient.delete(`/api/courses/${courseId}`);
}

