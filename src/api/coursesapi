import axiosClient from './axiosClient';

function normalizeCourse(course) {
  return {
    courseId: course.courseId ?? course.CourseId,
    instituteId: course.instituteId ?? course.InstituteId,
    courseName: course.courseName ?? course.CourseName ?? '',
    category: course.category ?? course.Category ?? '',
    description: course.description ?? course.Description ?? '',
    fees: course.fees ?? course.Fees ?? null,
    duration: course.duration ?? course.Duration ?? '',
    eligibility: course.eligibility ?? course.Eligibility ?? '',
    isAIFetched: course.isAIFetched ?? course.IsAIFetched ?? false,
    isApproved: course.isApproved ?? course.IsApproved ?? false,
    isActive: course.isActive ?? course.IsActive ?? false,
    createdAt: course.createdAt ?? course.CreatedAt,
    rateType: course.rateType ?? course.RateType ?? '',
    commissionRate: course.commissionRate ?? course.CommissionRate ?? 0,
  };
}

/**
 * Fetch all courses, optionally filtered by instituteId.
 * Backend also returns GstPercentage alongside the list -
 * we surface both in case you need GST for fee display later.
 */
export async function fetchCourses(instituteId) {
  const { data } = await axiosClient.get('/api/courses', {
    params: instituteId ? { instituteId } : {},
  });

  const rawCourses = data.courses ?? data.Courses ?? [];
  const gstPercentage = data.gstPercentage ?? data.GstPercentage ?? 0;

  return {
    gstPercentage,
    courses: rawCourses.map((c) => ({
      id: String(c.courseId ?? c.CourseId),
      ...normalizeCourse(c),
    })),
  };
}

export async function fetchCourseById(courseId) {
  const { data } = await axiosClient.get(`/api/courses/${courseId}`);
  return normalizeCourse(data);
}

export async function createCourse(form) {
  const instituteId = Number(form.instituteId);
  if (!instituteId) {
    throw new Error('Please select an institute');
  }
  if (!form.courseName?.trim()) {
    throw new Error('Course name is required');
  }

  const { data } = await axiosClient.post('/api/courses', {
    instituteId,
    courseName: form.courseName.trim(),
    category: form.category?.trim() || null,
    description: form.description?.trim() || null,
    fees: form.fees !== '' && form.fees != null ? Number(form.fees) : null,
    duration: form.duration?.trim() || null,
    eligibility: form.eligibility?.trim() || null,
    isAIFetched: Boolean(form.isAIFetched),
  });

  return normalizeCourse(data);
}

export async function updateCourse(courseId, form) {
  const instituteId = Number(form.instituteId);
  if (!instituteId) {
    throw new Error('Please select an institute');
  }
  if (!form.courseName?.trim()) {
    throw new Error('Course name is required');
  }

  const { data } = await axiosClient.put(`/api/courses/${courseId}`, {
    instituteId,
    courseName: form.courseName.trim(),
    category: form.category?.trim() || null,
    description: form.description?.trim() || null,
    fees: form.fees !== '' && form.fees != null ? Number(form.fees) : null,
    duration: form.duration?.trim() || null,
    eligibility: form.eligibility?.trim() || null,
  });

  return normalizeCourse(data);
}

export async function approveCourse(courseId) {
  const { data } = await axiosClient.put(`/api/courses/${courseId}/approve`);
  return normalizeCourse(data);
}

export async function deleteCourse(courseId) {
  await axiosClient.delete(`/api/courses/${courseId}`);
}

export function buildCourseForm(course) {
  return {
    instituteId: course.instituteId ? String(course.instituteId) : '',
    courseName: course.courseName || '',
    category: course.category || '',
    description: course.description || '',
    fees: course.fees ?? '',
    duration: course.duration || '',
    eligibility: course.eligibility || '',
    isAIFetched: course.isAIFetched || false,
  };
}

export function getEmptyCourseForm(instituteId) {
  return {
    instituteId: instituteId ? String(instituteId) : '',
    courseName: '',
    category: '',
    description: '',
    fees: '',
    duration: '',
    eligibility: '',
    isAIFetched: false,
  };
}