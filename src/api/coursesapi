export async function fetchCourseList() {
  const { data } = await axiosClient.get('/api/courses/GetCourses');
  const list = Array.isArray(data)
    ? data
    : (data?.courses ?? data?.Courses ?? data?.data ?? data?.Data ?? []);

  let instituteNameById = {};
  try {
    const { fetchUniqueInstituteNames } = await import('./institutesScrappingApi');
    const institutes = await fetchUniqueInstituteNames();
    instituteNameById = Object.fromEntries(
      (institutes ?? []).map((item) => [String(item.id), item.name || '']),
    );
  } catch {
    instituteNameById = {};
  }

  return (list ?? []).map((raw) => {
    const course = normalizeCourse(raw);
    return {
      ...course,
      id: String(course.courseId),
      courseCategory: course.category || '',
      instituteName:
        course.instituteName ||
        instituteNameById[String(course.instituteId)] ||
        '',
    };
  });
}
export async function approveCourse(courseId) {
  const { data } = await axiosClient.put(`/api/courses/${courseId}/approve`);
  return normalizeCourse(data);
}

export async function deleteCourse(courseId) {
  await axiosClient.delete(`/api/courses/${courseId}`);
}

